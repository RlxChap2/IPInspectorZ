{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "IP Inspector Z",
  "version": "1.0.0",
  "identifier": "com.ipinspectorz.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "IP Inspector Z",
        "width": 960,
        "height": 720,
        "minWidth": 520,
        "minHeight": 400,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "longDescription": "Lightweight desktop app for network and device diagnostics. Shows public IP, geo data, local network info, device specs, and leak detection.",
    "shortDescription": "Network & device diagnostics",
    "category": "Utility",
    "copyright": "",
    "licenseFile": null,
    "resources": [],
    "externalBin": [],
    "publisher": null,
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "",
      "entitlements": null,
      "signingIdentity": null,
      "providerShortName": null
    }
  },
  "plugins": {}
}
